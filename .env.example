# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/parcelpeer

# JWT
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_min_32_chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Firebase
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email@iam.gserviceaccount.com
FCM_SERVER_KEY=your_fcm_server_key

# Paystack
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# Server
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000/api

# Geocoding
NOMINATIM_API=https://nominatim.openstreetmap.org

# File Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Error Tracking (Optional)
SENTRY_DSN=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10
